# ============================================================
# mindvaults 环境变量配置
# 复制此文件为 .env 后按需修改
# ============================================================

# --- 数据库 (PostgreSQL + pgvector) ---
DATABASE_URL=postgresql+asyncpg://mindvaults:mindvaults@db:5432/mindvaults

# --- Redis ---
REDIS_URL=redis://redis:6379
REDIS_CACHE_TTL=3600
REDIS_CACHE_ENABLED=true

# --- LLM 配置 -------------------------------------------------
# provider: ollama (本地模型) | openai (云端/兼容 API)
LLM_PROVIDER=ollama
# ollama 模式: http://ollama:11434 (不用加 /v1)
# openai 模式: https://api.deepseek.com/v1 (结尾带 /v1)
LLM_BASE_URL=http://ollama:11434
# ollama 模式: qwen3 / qwen2.5:1.5b / qwen2.5:0.5b
# openai 模式: deepseek-chat / gpt-4o / qwen-plus
LLM_MODEL=qwen3
# openai 模式需要填写 API Key (ollama 留空)
LLM_API_KEY=

# --- Embedding 配置 -------------------------------------------
# provider: ollama (本地模型) | openai (云端/兼容 API)
EMBEDDING_PROVIDER=ollama
# ollama 模式: BAAI/bge-large-zh-v1.5 (1024维) / bge-small-zh-v1.5 (384维)
# openai 模式: text-embedding-3-small / text-embedding-ada-002
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
# 向量维度 (需与模型匹配)
EMBEDDING_DIM=1024
# 独立的 Embedding 服务地址 (留空则复用 LLM_BASE_URL)
EMBEDDING_BASE_URL=
# 独立的 Embedding API Key (留空则复用 LLM_API_KEY)
EMBEDDING_API_KEY=

# --- 应用 ---
APP_ENV=development
APP_DEBUG=true
API_KEY=change-me-in-production

# --- 前端 ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost

# --- 限流 ---
RATE_LIMIT_ENABLED=true

# --- 日志 ---
LOG_LEVEL=INFO
LOG_DIR=/app/logs
LOG_RETENTION=30

# --- 上传 ---
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS=txt,md,pdf,docx,doc

# ============================================================
# 常用配置组合:
#
# 【纯本地】全部 Ollama:
#   LLM_PROVIDER=ollama
#   EMBEDDING_PROVIDER=ollama
#
# 【云端 LLM + 本地 Embedding】节省显存:
#   LLM_PROVIDER=openai
#   LLM_BASE_URL=https://api.deepseek.com/v1
#   LLM_MODEL=deepseek-chat
#   LLM_API_KEY=sk-your-key
#   EMBEDDING_PROVIDER=ollama
#
# 【低配服务器】小模型 + 低内存:
#   LLM_MODEL=qwen2.5:0.5b
#   EMBEDDING_MODEL=bge-small-zh-v1.5
#   EMBEDDING_DIM=384
# ============================================================
